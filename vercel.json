{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/og.js": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    { "source": "/@:slug", "destination": "/api/og?userSlug=:slug" },
    { "source": "/calendar/:slug/:tab", "destination": "/api/og?calSlug=:slug" },
    { "source": "/calendar/:slug", "destination": "/api/og?calSlug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
