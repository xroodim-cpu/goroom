{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/og.js": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    { "source": "/@:slug", "destination": "/api/og?slug=:slug" },
    { "source": "/calendar/:roomId/:tab", "destination": "/api/og?roomId=:roomId" },
    { "source": "/calendar/:roomId", "destination": "/api/og?roomId=:roomId" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
